# Ornith-1.0-9B — agentic coding model (Qwen3.5 dense, reasoning + tool calls)
#
#   ollama create ornith-9b -f modelfiles/ornith-9b.Modelfile
#   ollama run ornith-9b
#
# Sourced from Ollama's official library. Q8_0 (~9.5 GB) is near-lossless and
# fits any >=12 GB GPU. Smaller: ornith:9b-q4_K_M (5.6 GB) or the bare ornith:9b
# (Q4_K_M default). Larger: ornith:9b-bf16 (18 GB). Pulled on first `create`.
FROM ornith:9b-q8_0

# Sampling params recommended by the model card (deepreinforce-ai).
# NOTE: ollama-test.py passes its own --temp/--top_p, which override these during
# benchmarks; they apply when you `ollama run` / call the API without options.
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20

# Native context is 262144. 32K is a safe default that fits most GPUs; raise it
# if you have VRAM headroom (KV-cache grows with context). Set the server env
# OLLAMA_KV_CACHE_TYPE=q8_0 to roughly halve KV-cache memory for long contexts.
PARAMETER num_ctx 32768
